# Provedor de embedding: "ollama" (local, gratuito) ou "openai" (pago)
TOTAL_RECALL_CODEX_EMBED_PROVIDER=ollama

# Chave da OpenAI (só se TOTAL_RECALL_CODEX_EMBED_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Diretório de dados (padrão: ~/.total-recall-codex/)
# TOTAL_RECALL_CODEX_DATA=~/.total-recall-codex

# Raiz das sessões Codex (padrão: ~/.codex/sessions/)
# TOTAL_RECALL_CODEX_SESSIONS=~/.codex/sessions
