# Vozes da Comunidade — configuração de ambiente
# Copie este arquivo para .env e ajuste os valores

# ---------------------------------------------------------------------------
# Motor de extração ASTE
# ---------------------------------------------------------------------------
# bertimbau → Plano A: BERTimbau fine-tuned (requer checkpoint)
# slm       → Plano B: SLM local via ollama ou MLX (funciona imediatamente)
ASTE_BACKEND=slm

# ---------------------------------------------------------------------------
# Plano A — BERTimbau fine-tuned
# ---------------------------------------------------------------------------
# Caminho para o diretório do checkpoint fine-tuned.
# Deixe vazio enquanto o fine-tuning ainda não foi realizado.
# O sistema fará fallback automático para o SLM com aviso no log.
BERTIMBAU_MODEL_PATH=

# Caminho para o diretório raiz do dinamica_absa (TCC)
DINAMICA_ABSA_PATH=/Users/criacao/Library/CloudStorage/OneDrive-Embelleze/MEUS-PROJETOS-IA/COLETA-COMENTARIOS-TIKTOK/PROCESSAMENTO-COLETA/kimi/dinamica_absa

BERTIMBAU_MAX_LENGTH=128
BERTIMBAU_BATCH_SIZE=16

# ---------------------------------------------------------------------------
# Plano B — SLM local
# ---------------------------------------------------------------------------
# Backend: ollama (mais simples) ou mlx (nativo Apple Silicon, mais rápido)
SLM_BACKEND=ollama

# Modelo:
#   Para ollama:  qwen2.5:7b | phi3.5 | mistral
#   Para MLX:     mlx-community/Qwen2.5-7B-Instruct-4bit  (4.28 GB, cabe em M1 16GB)
#                 mlx-community/Qwen2.5-7B-Instruct-8bit  (8.09 GB, tight em M1 16GB)
SLM_MODEL=qwen2.5:7b

# Endereço do servidor ollama (padrão: localhost)
OLLAMA_HOST=http://localhost:11434

SLM_MAX_TOKENS=512
SLM_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Thresholds de qualidade
# ---------------------------------------------------------------------------
MIN_CONFIDENCE=0.5
BRIEFING_RELEVANCE_THRESHOLD=0.6

# ---------------------------------------------------------------------------
# Integração com Memória Viva (Agente 8)
# ---------------------------------------------------------------------------
# Caminho para src/ do projeto memoria-viva — para gravar no Warm Store.
# Deixe vazio para usar fallback JSON local (data/vozes_cache/).
MEMORIA_VIVA_PATH=/Users/criacao/Library/CloudStorage/OneDrive-Embelleze/MEUS-PROJETOS-IA/AGENTES/CLAUDE/projetos/memoria-viva/src

# ---------------------------------------------------------------------------
# API Anthropic (síntese via Claude Haiku)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
SYNTHESIS_MODEL=claude-haiku-4-5-20251001
