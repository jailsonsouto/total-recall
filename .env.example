# Provedor de embedding: "nomic" (local, gratuito) ou "openai" (pago)
TOTAL_RECALL_EMBED_PROVIDER=nomic

# Chave da OpenAI (só se TOTAL_RECALL_EMBED_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Diretório de dados (padrão: ~/.total-recall/)
# TOTAL_RECALL_DATA=~/.total-recall

# Raiz dos projetos Claude Code (padrão: ~/.claude/projects/)
# TOTAL_RECALL_SESSIONS=~/.claude/projects
